# DocTranslate — Environment Variables
# Copy this file to .env and update values as needed

# Server Configuration
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO

# Admin API key for POST /documents and other protected endpoints
# Change this in production!
ADMIN_KEY=change-me-in-production

# Demo admin key used by the frontend and public demo
# Must match ADMIN_KEY for full admin access
DEMO_ADMIN_KEY=change-me-in-production

# DeepSeek API key for AI-powered translation and explanations
# If not set, falls back to MyMemory API
DEEPSEEK_API_KEY=

# MyMemory API email (optional, for higher translation rate limits)
MYMEMORY_EMAIL=
